rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can only write their own profile, anyone authenticated can read (for backoffice)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Runs: can only create their own runs, anyone authenticated can read
    match /runs/{runId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Events: can only create their own events, anyone authenticated can read
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
